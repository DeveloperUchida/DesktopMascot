<Window
    x:Class="DesktopMascot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    Title="DesktopMascot"

    Width="300"
    Height="200"

    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ResizeMode="NoResize">

    <Border
        Background="#DDFFFFFF"
        CornerRadius="20"
        Padding="20">

        <StackPanel>
            <TextBlock
                FontSize="48"
                HorizontalAlignment="Center"
                Text="🐱"/>

            <TextBlock
                x:Name="MessageText"
                FontSize="18"
                HorizontalAlignment="Center"
                Text="おはよう〜！作業えらい！✨"/>

            <TextBlock
                x:Name="WorkTimeText"
                FontSize="14"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Text="作業時間: 00:00:00"/>
            <Button
                Content="🖼️ 画像を変更"
                Margin="0,10,0,0"
                Click="ChangeImageButton_Click"/>
            
        </StackPanel>

    </Border>

</Window>