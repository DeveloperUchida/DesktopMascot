<Window
    x:Class="DesktopMascot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    Title="DesktopMascot"

    Width="300"
    Height="200"

    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ResizeMode="NoResize">

    <Border
        Background="#DDFFFFFF"
        CornerRadius="20"
        Padding="20">

        <StackPanel>
            <TextBlock
                FontSize="48"
                HorizontalAlignment="Center"
                Text="🐱"/>

            <TextBlock
                x:Name="MessageText"
                FontSize="18"
                HorizontalAlignment="Center"
                Text="おはよう〜！作業えらい！✨"/>
        </StackPanel>

    </Border>

</Window>